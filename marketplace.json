[
  {
    "id": "neon-punk",
    "name": "Neon Punk",
    "author": "ElChagnon",
    "type": "theme",
    "color": "#ff00ff",
    "css": "body,html,.Root__main-view,.main-view-container__scroll-node-child,#main-view,section[data-testid=\"home-page\"]{background:#0a0a0a!important}div[data-testid=\"grid-container\"]>div,div[data-testid=\"card-container\"]{background:rgba(255,0,255,0.05)!important;border:1px solid #ff00ff!important;box-shadow:0 0 10px rgba(255,0,255,0.2)!important;border-radius:0!important}h1,h2,h3,span,p{color:#0ff!important;text-shadow:0 0 5px #0ff!important}button[data-testid=\"play-button\"]{background:#ff00ff!important;border-radius:0!important;box-shadow:0 0 15px #ff00ff!important}button[data-testid=\"play-button\"] *{fill:#0a0a0a!important}aside[data-testid=\"now-playing-bar\"]{background:rgba(10,10,10,0.9)!important;border-top:1px solid #0ff!important;box-shadow:0 -5px 20px rgba(0,255,255,0.2)!important;border-radius:0!important}form[role=\"search\"] input{border-radius:0!important;border:1px solid #ff00ff!important;background:rgba(255,0,255,0.05)!important}"
  },
  {
    "id": "hacker-mode",
    "name": "Hacker Mode",
    "author": "ElChagnon",
    "type": "theme",
    "color": "#00ff00",
    "css": "body,html,.Root__main-view,.main-view-container__scroll-node-child,#main-view,section[data-testid=\"home-page\"]{background:#000!important;font-family:monospace!important}div[data-testid=\"grid-container\"]>div,div[data-testid=\"card-container\"]{background:transparent!important;border:1px dashed #00ff00!important;border-radius:0!important}h1,h2,h3,span,p{color:#00ff00!important}button[data-testid=\"play-button\"]{background:#000!important;border:1px solid #00ff00!important;border-radius:0!important}button[data-testid=\"play-button\"] *{fill:#00ff00!important}aside[data-testid=\"now-playing-bar\"]{background:#000!important;border-top:1px dashed #00ff00!important;border-radius:0!important}form[role=\"search\"] input{border-radius:0!important;border:1px dashed #00ff00!important;background:#000!important;color:#00ff00!important;font-family:monospace!important}"
  },
  {
    "id": "fun-lyrics",
    "name": "Bouton Paroles Magique",
    "author": "ElChagnon",
    "type": "extension",
    "desc": "Affiche une alerte rigolote quand on essaie d'ouvrir les paroles.",
    "js": "let lp = setInterval(() => { let btn = document.querySelector('button[data-testid=\"lyrics-button\"]'); if(btn && !btn.hasAttribute('data-magique')) { btn.setAttribute('data-magique','1'); btn.addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); alert('Oups! Les paroles sont parties en vacances 🏖️'); }); } }, 2000);"
  }
]